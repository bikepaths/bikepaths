            width: 20px;
            text-align: center;
            opacity: 0.7;
        }
        .breadcrumb {
            text-align: left;
            margin-bottom: 25px;
            font-size: 0.9rem;
            color: #555;
        }
        .breadcrumb a {
            color: #888;
            text-decoration: none;
        }
        .breadcrumb a:hover { color: #fff; }
        .empty-msg {
            color: #444;
            font-style: italic;
            margin-top: 10px;
        }
    </style>
</head>
<body>
    <div class="container">
        <div style="text-align: left;">
            <a href="/blog/">
                <img src="/blog/themes/blog/images/logo.png" alt="Bikepaths Logo" class="hero-img">
            </a>
        </div>
        
        <div class="topics-section">
            <div class="breadcrumb">
                <a href="/">Home</a> / 
                <a href="/topics/">Topics</a>
                <?php if ($rel): ?>
                    <?php 
                    $parts = explode('/', $rel);
                    $accum = '';
                    foreach ($parts as $part): 
                        $accum .= ($accum ? '/' : '') . $part;
                        echo ' / <a href="/topics/' . htmlspecialchars($accum) . '/">' . htmlspecialchars(str_replace(['_', '-'], ' ', $part)) . '</a>';
                    endforeach; 
                    ?>
                <?php endif; ?>
            </div>
            
            <h1><?php echo $rel ? htmlspecialchars(str_replace(['_', '-'], ' ', basename($rel))) : 'Archive & Insights'; ?></h1>

            <?php if (!empty($folders)): ?>
                <span class="category-title">Collections</span>
                <ul>
                    <?php foreach ($folders as $folder): 
                        $link = htmlspecialchars($folder) . '/';
                        if (file_exists($dir . '/' . $folder . '/index.php')) {
                            $link .= 'index.php';
                        }
                    ?>
                        <li>
                            <a href="<?php echo $link; ?>" class="item-link">
                                <span class="icon">📁</span>
                                <?php echo htmlspecialchars(str_replace(['_', '-'], ' ', $folder)); ?>
                            </a>
                        </li>
                    <?php endforeach; ?>
                </ul>
            <?php endif; ?>

            <?php if (!empty($files)): ?>
                <span class="category-title">Documents</span>
                <ul>
                    <?php foreach ($files as $file): ?>
                        <li>
                            <a href="<?php echo htmlspecialchars($file); ?>" class="item-link">
                                <span class="icon">📄</span>
                                <?php echo htmlspecialchars(str_replace(['_', '-'], ' ', pathinfo($file, PATHINFO_FILENAME))); ?>
                            </a>
                        </li>
                    <?php endforeach; ?>
                </ul>
            <?php endif; ?>

            <?php if (empty($folders) && empty($files)): ?>
                <p class="empty-msg">No files found in this collection.</p>
            <?php endif; ?>
        </div>
    </div>
</body>
</html>
