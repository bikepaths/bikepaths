<?php
/**
 * Universal Dynamic Index for Bikepaths.org Topics
 */
$root = dirname(__FILE__);
$rel = isset($_GET['path']) ? $_GET['path'] : '';

// Security: No parent directory access, no leading/trailing slashes for consistency
$rel = trim(str_replace('..', '', $rel), '/');

$dir = $root;
if ($rel) {
    $target = realpath($root . '/' . $rel);
    if ($target && strpos($target, $root) === 0 && is_dir($target)) {
        $dir = $target;
    } else {
        $rel = ''; // Fallback to root
    }
}

$items = scandir($dir);
$files = [];
$folders = [];

foreach ($items as $item) {
    if ($item[0] === '.' || $item === 'index.php' || $item === '.htaccess') continue;
    
    $path = $dir . '/' . $item;
    if (is_dir($path)) {
        $folders[] = $item;
    } else {
        $files[] = $item;
    }
}

sort($folders);
sort($files);

$displayPath = $rel ? ' / ' . htmlspecialchars(str_replace(['_', '-'], ' ', $rel)) : '';
?>
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Bikepaths - Topics Index <?php echo $displayPath; ?></title>
    <meta name="description" content="Bikepaths Topics Archive - A collection of strategic insights, working papers, audio series, and research documents on governance and structural decoupling." />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600&display=swap" rel="stylesheet">
    <style>
        body {
            background-color: #000;
            color: #e0e0e0;
            font-family: 'Inter', -apple-system, sans-serif;
            margin: 0;
            padding: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
        }
        .container {
            max-width: 800px;
            width: 90%;
            text-align: center;
            padding: 40px 20px;
        }
        .hero-img {
            max-width: 100%;
            max-height: 70px;
            height: auto;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
