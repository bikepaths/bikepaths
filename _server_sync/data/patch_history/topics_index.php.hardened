        }
        ul { list-style: none; padding: 0; margin: 0; }
        li {
            margin: 0;
            border-bottom: 1px solid #111;
        }
        li:last-child { border-bottom: none; }
        .item-link {
            display: flex;
            align-items: center;
            padding: 12px 0;
            color: #aaa;
            text-decoration: none;
            font-size: 1.05rem;
            transition: color 0.2s, padding-left 0.2s;
        }
        .item-link:hover {
            color: #fff;
            padding-left: 8px;
            background: rgba(255,255,255,0.02);
        }
        .icon {
            margin-right: 15px;
