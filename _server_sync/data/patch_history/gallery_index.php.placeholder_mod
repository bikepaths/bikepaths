class Gallery {
    private $config;
    private $fileManager;
    private $imageProcessor;
    private $uiRenderer;

    public function __construct($config) {
        $this->config = $config;
        $this->fileManager = new FileManager($config);
        $this->imageProcessor = new ImageProcessor($config);
        $this->uiRenderer = new UIRenderer($config);
    }

    public function handleRequest() {
        if (isset($_GET['thumb'])) {
            $size = isset($_GET['size']) ? intval($_GET['size']) : $this->config['default_thumb_size'];
            $this->imageProcessor->generateThumbnail($_GET['thumb'], $size);
            return;
        }
        $current_dir = isset($_GET['dir']) ? str_replace(['../', './'], '', $_GET['dir']) : '';
        $full_path = rtrim($this->config['gallery_root'] . '/' . $current_dir, '/');
        $content = $this->fileManager->scanDirectory($full_path);
        $page = isset($_GET['page']) ? max(1, intval($_GET['page'])) : 1;
        $total_files = count($content['files']);
        $total_pages = ceil($total_files / $this->config['per_page']);
        $thumb_size = isset($_GET['size']) ? intval($_GET['size']) : $this->config['default_thumb_size'];
        if (!in_array($thumb_size, $this->config['thumb_sizes'])) $thumb_size = $this->config['default_thumb_size'];
        echo $this->uiRenderer->renderHTML($content, $current_dir, $page, $total_pages, $thumb_size);
    }
}

$gallery = new Gallery($config);
