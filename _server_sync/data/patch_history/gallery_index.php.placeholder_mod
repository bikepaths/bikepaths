// Helper to get granular file type and icon
function getFileInfo($filename) {
    $ext = strtolower(pathinfo($filename, PATHINFO_EXTENSION));
    $map = [
        'jpg' => ['type' => 'image', 'icon' => '🖼️'],
        'jpeg' => ['type' => 'image', 'icon' => '🖼️'],
        'png' => ['type' => 'image', 'icon' => '🖼️'],
        'gif' => ['type' => 'image', 'icon' => '🖼️'],
        'webp' => ['type' => 'image', 'icon' => '🖼️'],
        'avif' => ['type' => 'image', 'icon' => '🖼️'],
        'pdf' => ['type' => 'doc', 'icon' => '📕'],
        'htm' => ['type' => 'doc', 'icon' => '🌐'],
        'html' => ['type' => 'doc', 'icon' => '🌐'],
        'txt' => ['type' => 'doc', 'icon' => '📄'],
        'md' => ['type' => 'doc', 'icon' => '📝'],
        'mp3' => ['type' => 'audio', 'icon' => '📻'],
        'ogg' => ['type' => 'audio', 'icon' => '📻'],
        'wav' => ['type' => 'audio', 'icon' => '🎵'],
        'm4a' => ['type' => 'audio', 'icon' => '🎵'],
        'mp4' => ['type' => 'video', 'icon' => '🎬'],
        'webm' => ['type' => 'video', 'icon' => '🎥'],
        'mov' => ['type' => 'video', 'icon' => '🎞️'],
        'yt' => ['type' => 'youtube', 'icon' => '📺']
    ];
    
    if (isset($map[$ext])) return $map[$ext];
    
    // Fallback categories
    $types = [
        'image' => ['bmp', 'tiff', 'tif'],
        'doc' => [],
        'audio' => [],
        'video' => []
    ];
    
    foreach ($types as $type => $extensions) {
        if (in_array($ext, $extensions)) {
            switch ($type) {
                case 'image': return ['type' => 'image', 'icon' => '🖼️'];
                case 'doc': return ['type' => 'doc', 'icon' => '📄'];
                case 'audio': return ['type' => 'audio', 'icon' => '🎵'];
                case 'video': return ['type' => 'video', 'icon' => '🎥'];
            }
        }
    }
    
    return ['type' => 'other', 'icon' => '❓'];
}

// FileManager Class
class FileManager {
    private $config;

    public function __construct($config) {
        $this->config = $config;
        $this->ensureDirectories();
    }

    private function ensureDirectories() {
        $dirs = [$this->config['thumb_dir'], $this->config['metadata_dir']];
        foreach ($dirs as $dir) {
            if (!is_dir($dir)) {
                mkdir($dir, 0755, true);
            }
        }
    }

    public function scanDirectory($dir) {
        if (!is_dir($dir)) return ['dirs' => [], 'files' => []];

        $items = scandir($dir);
        $directories = [];
        $files = [];

        foreach ($items as $item) {
            if ($item == '.' || $item == '..') continue;

            $full_item = $dir . '/' . $item;

            if (is_dir($full_item)) {
                $directories[] = [
                    'name' => $item,
                    'path' => $item,
                    'mtime' => filemtime($full_item)
                ];
            } else {
                $ext = strtolower(pathinfo($item, PATHINFO_EXTENSION));
                if (in_array($ext, $this->config['allowed_extensions'])) {
                    $info = getFileInfo($item);
                    $yt_id = '';
                    if ($ext === 'yt') {
                        $yt_id = trim(file_get_contents($full_item));
                    }
                    $files[] = [
                        'name' => $item,
                        'path' => $item,
                        'type' => $info['type'],
                        'icon' => $info['icon'],
                        'mtime' => filemtime($full_item),
                        'size' => filesize($full_item),
                        'yt_id' => $yt_id
                    ];
                }
            }
        }

        usort($directories, function($a, $b) { return $b['mtime'] - $a['mtime']; });
        usort($files, function($a, $b) { return $b['mtime'] - $a['mtime']; });

        return ['dirs' => $directories, 'files' => $files];
    }
}

// ImageProcessor Class
class ImageProcessor {
    private $config;

    public function __construct($config) {
        $this->config = $config;
    }

    public function generateThumbnail($image_path, $size = null) {
        $info = getFileInfo($image_path);
        
        // If not an image or if list view (size 0), we render an icon
        if ($info['type'] !== 'image' || $size === 0) {
            $this->renderIcon($info['icon'], $size ?: 48);
            return true;
        }

        $size = $size ?: $this->config['default_thumb_size'];
        $source_file = $this->config['gallery_root'] . '/' . $image_path;
        $thumb_file = $this->config['thumb_dir'] . '/' . $size . '_' . str_replace(['/', '\\'], '_', $image_path);

        if (!file_exists($source_file)) {
            http_response_code(404);
            return false;
        }

        if (file_exists($thumb_file) && filemtime($thumb_file) >= filemtime($source_file)) {
            header('Content-Type: image/jpeg');
            header('Cache-Control: max-age=31536000');
            readfile($thumb_file);
            return true;
        }

        $image_info = @getimagesize($source_file);
        if (!$image_info) {
             $this->renderIcon($info['icon'], $size);
             return true;
        }

        $width = $image_info[0];
        $height = $image_info[1];
        $mime = $image_info['mime'];

        $ratio = min($size / $width, $size / $height);
        $new_width = $width * $ratio;
        $new_height = $height * $ratio;

        $source = $this->createImageResource($source_file, $mime);
        if (!$source) {
             $this->renderIcon($info['icon'], $size);
             return true;
        }

        $thumbnail = imagecreatetruecolor($new_width, $new_height);

        if ($mime == 'image/png' || $mime == 'image/gif') {
            imagealphablending($thumbnail, false);
            imagesavealpha($thumbnail, true);
            $transparent = imagecolorallocatealpha($thumbnail, 255, 255, 255, 127);
            imagefill($thumbnail, 0, 0, $transparent);
        }

        imagecopyresampled($thumbnail, $source, 0, 0, 0, 0, $new_width, $new_height, $width, $height);
        imagejpeg($thumbnail, $thumb_file, 85);

        imagedestroy($source);
        imagedestroy($thumbnail);

        header('Content-Type: image/jpeg');
        header('Cache-Control: max-age=31536000');
        readfile($thumb_file);
        return true;
    }

    private function renderIcon($icon, $size) {
        $size = max(32, $size);
        $im = imagecreatetruecolor($size, $size);
        $bg = imagecolorallocate($im, 248, 249, 250);
        $text_color = imagecolorallocate($im, 50, 50, 50);
        imagefill($im, 0, 0, $bg);
        
        $font_size = ($size > 100) ? 5 : 3;
        $text = $icon;
        $tw = imagefontwidth($font_size) * mb_strlen($text);
        $th = imagefontheight($font_size);
        imagestring($im, $font_size, ($size-$tw)/2, ($size-$th)/2, $text, $text_color);
        
        header('Content-Type: image/png');
        imagepng($im);
        imagedestroy($im);
    }

    private function createImageResource($file, $mime) {
        switch ($mime) {
            case 'image/jpeg': return imagecreatefromjpeg($file);
            case 'image/png': return imagecreatefrompng($file);
            case 'image/gif': return imagecreatefromgif($file);
            case 'image/webp': return imagecreatefromwebp($file);
            case 'image/avif': return function_exists('imagecreatefromavif') ? imagecreatefromavif($file) : false;
            default: return false;
        }
    }

    public function getImageMetadata($image_path) {
        $info = getFileInfo($image_path);
        if (!$this->config['enable_exif'] || $info['type'] !== 'image') return [];

        $source_file = $this->config['gallery_root'] . '/' . $image_path;
        $cache_file = $this->config['metadata_dir'] . '/meta_' . md5($image_path) . '.json';

        if (file_exists($cache_file) && filemtime($cache_file) >= filemtime($source_file)) {
            return json_decode(file_get_contents($cache_file), true);
        }

        $metadata = [];
        if (function_exists('exif_read_data')) {
            $exif = @exif_read_data($source_file);
            if ($exif) {
                $metadata['camera'] = isset($exif['Model']) ? $exif['Model'] : '';
                $metadata['datetime'] = isset($exif['DateTime']) ? $exif['DateTime'] : '';
                if (isset($exif['GPSLatitude']) && isset($exif['GPSLongitude'])) {
                    $lat = $this->gpsToDecimal($exif['GPSLatitude'], $exif['GPSLatitudeRef']);
                    $lng = $this->gpsToDecimal($exif['GPSLongitude'], $exif['GPSLongitudeRef']);
                    if ($lat && $lng) {
                        $metadata['gps'] = ['lat' => $lat, 'lng' => $lng];
                        if ($this->config['enable_geocoding']) {
                            $metadata['maps_url'] = "https://maps.google.com/?q={$lat},{$lng}";
                        }
                    }
                }
            }
        }
        file_put_contents($cache_file, json_encode($metadata));
        return $metadata;
    }

    private function gpsToDecimal($coordinate, $hemisphere) {
        if (!is_array($coordinate) || count($coordinate) != 3) return false;
        $degrees = count($coordinate) > 0 ? $this->gpsToFloat($coordinate[0]) : 0;
        $minutes = count($coordinate) > 1 ? $this->gpsToFloat($coordinate[1]) : 0;
        $seconds = count($coordinate) > 2 ? $this->gpsToFloat($coordinate[2]) : 0;
        $decimal = $degrees + ($minutes / 60) + ($seconds / 3600);
        if ($hemisphere == 'S' || $hemisphere == 'W') $decimal *= -1;
        return $decimal;
    }

    private function gpsToFloat($rational) {
        if (strpos($rational, '/') !== false) {
            $parts = explode('/', $rational);
            return $parts[1] != 0 ? $parts[0] / $parts[1] : 0;
        }
        return floatval($rational);
    }
}

